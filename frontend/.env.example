# Google Maps JavaScript API key (browser)
# Enable: Maps JavaScript API
VITE_GOOGLE_MAPS_API_KEY=

# Native (APK/Capacitor) override for Google Maps JS API.
# Recommended if your web key is HTTP-referrer restricted to your Vercel domain.
# In Capacitor Android the WebView origin is typically http://localhost, so the
# web key may be rejected with a "RefererNotAllowedMapError".
# VITE_NATIVE_GOOGLE_MAPS_API_KEY=

# Native dev host (Capacitor):
# - Android emulator: 10.0.2.2 (default)
# - Physical device: your PC's LAN IP (e.g. 192.168.1.50)
# VITE_DEV_HOST=10.0.2.2

# Route optimizer service (FastAPI)
# Local (docker-compose): http://localhost:8002
# Local (python -m backend.routeOptimizer): http://localhost:8000
VITE_ROUTE_OPTIMIZER_BASE_URL=

# Auth service (Node/Express)
VITE_AUTH_URL=http://localhost:5001

# Native-only override (APK/Capacitor). Useful when web uses Vercel rewrites
# but the APK should talk directly to AWS (e.g. ALB DNS).
# VITE_NATIVE_AUTH_URL=http://ceylonroam-alb-xxxx.us-east-1.elb.amazonaws.com

# Itinerary generator service (FastAPI)
# Note the /api prefix here.
VITE_API_BASE_URL=http://localhost:8001/api

# Native-only override
# VITE_NATIVE_API_BASE_URL=http://ceylonroam-alb-xxxx.us-east-1.elb.amazonaws.com:8001/api

# Voice translation service (FastAPI)
VITE_API_URL=http://localhost:8003

# Native-only override
# VITE_NATIVE_API_URL=http://ceylonroam-alb-xxxx.us-east-1.elb.amazonaws.com:8003

# Backend needs its own server-side key for live traffic optimization:
# - set GOOGLE_MAPS_API_KEY in backend environment (Enable Distance Matrix API; billing required)
