# Development overrides for `npm run dev`
# These values override `frontend/.env` when running in Vite development mode.

# Use local backends during development to avoid CORS.
# Leave base URLs empty to use same-origin routes + Vite proxy.
VITE_API_BASE_URL=
VITE_ROUTE_OPTIMIZER_BASE_URL=
VITE_API_URL=

# Auth service runs locally on port 5001 in development.
# Keep empty for web dev so requests go same-origin via Vite proxy.
VITE_AUTH_URL=
