{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,PATCH,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/signup",
      "destination": "http://ceylonroam-alb-1374093111.us-east-1.elb.amazonaws.com/api/signup"
    },
    {
      "source": "/api/login",
      "destination": "http://ceylonroam-alb-1374093111.us-east-1.elb.amazonaws.com/api/login"
    },
    {
      "source": "/api/profile",
      "destination": "http://ceylonroam-alb-1374093111.us-east-1.elb.amazonaws.com/api/profile"
    },
    {
      "source": "/api/forgot-password",
      "destination": "http://ceylonroam-alb-1374093111.us-east-1.elb.amazonaws.com/api/forgot-password"
    },
    {
      "source": "/api/verify-otp",
      "destination": "http://ceylonroam-alb-1374093111.us-east-1.elb.amazonaws.com/api/verify-otp"
    },
    {
      "source": "/api/reset-password",
      "destination": "http://ceylonroam-alb-1374093111.us-east-1.elb.amazonaws.com/api/reset-password"
    },
    {
      "source": "/api/reset-password/request",
      "destination": "http://ceylonroam-alb-1374093111.us-east-1.elb.amazonaws.com/api/reset-password/request"
    },
    {
      "source": "/api/contact-us",
      "destination": "http://ceylonroam-alb-1374093111.us-east-1.elb.amazonaws.com/api/contact-us"
    },
    {
      "source": "/api/debug/users",
      "destination": "http://ceylonroam-alb-1374093111.us-east-1.elb.amazonaws.com/api/debug/users"
    },
    {
      "source": "/api/optimize",
      "destination": "http://ceylonroam-alb-1374093111.us-east-1.elb.amazonaws.com:8002/optimize"
    },
    {
      "source": "/api/traffic-route",
      "destination": "http://ceylonroam-alb-1374093111.us-east-1.elb.amazonaws.com:8002/traffic-route"
    },

    {
      "source": "/api/generate",
      "destination": "http://ceylonroam-alb-1374093111.us-east-1.elb.amazonaws.com:8001/api/generate"
    },
    {
      "source": "/api/meta",
      "destination": "http://ceylonroam-alb-1374093111.us-east-1.elb.amazonaws.com:8001/api/meta"
    },
    {
      "source": "/api/health",
      "destination": "http://ceylonroam-alb-1374093111.us-east-1.elb.amazonaws.com:8001/api/health"
    },

    {
      "source": "/voice/translate",
      "destination": "http://ceylonroam-alb-1374093111.us-east-1.elb.amazonaws.com:8003/voice/translate"
    },
    {
      "source": "/text/translate",
      "destination": "http://ceylonroam-alb-1374093111.us-east-1.elb.amazonaws.com:8003/text/translate"
    },

    {
      "source": "/api/:path*",
      "destination": "http://ceylonroam-alb-1374093111.us-east-1.elb.amazonaws.com/api/:path*"
    },

    {
      "source": "/:path*",
      "destination": "/"
    }
  ]
}
