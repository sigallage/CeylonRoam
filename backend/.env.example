# Environment variables for local Docker development

# MongoDB Configuration
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme123

# Auth Service
MONGODB_URI=mongodb://admin:changeme123@mongodb:27017/ceylonroam?authSource=admin
SESSION_SECRET=change_me_in_production
NODE_ENV=production

# Google Maps API (Required for Route Optimizer)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenRouter API (Optional - for AI-enhanced itineraries)
OPENROUTER_API_KEY=your_openrouter_api_key_here
